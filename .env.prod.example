# ===========================================
# KeyBudget — Production Environment
# Copy to .env.prod and fill in values.
# NEVER commit .env.prod to version control.
# Generate keys with: bash scripts/generate-keys.sh
# ===========================================

# --- Domain ---
# Your server's domain or IP address
DOMAIN=keybudget.example.com
FRONTEND_URL=https://keybudget.example.com

# --- PostgreSQL ---
DB_USERNAME=keybudget
DB_PASSWORD=

# --- Google OAuth2 ---
# Create at: https://console.cloud.google.com -> APIs & Services -> Credentials
# Authorized redirect URI: https://YOUR_DOMAIN/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- JWT RSA Keys (base64-encoded DER, NOT PEM) ---
# Generate with: bash scripts/generate-keys.sh
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- AES-256 Encryption Key ---
# Generate with: bash scripts/generate-keys.sh
ENCRYPTION_KEY=

# --- Ports (optional, defaults shown) ---
# Note: ports < 1024 require root on Linux; use 8443/8080 for unprivileged
HOST_PORT=443
HOST_PORT_HTTP=80
